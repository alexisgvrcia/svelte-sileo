{
  "name": "svelte-sileo",
  "version": "1.2.0",
  "description": "An opinionated, physics-based toast component for Svelte. Port of sileo.",
  "license": "MIT",
  "author": "Alexis Garcia <alexisgvrcia@gmail.com>",
  "homepage": "https://svelte-sileo.alexisgvrcia.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexisgvrcia/svelte-sileo.git"
  },
  "bugs": "https://github.com/alexisgvrcia/svelte-sileo/issues",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package",
    "prepublishOnly": "npm run package",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@fontsource-variable/fira-code": "5.2.7",
    "@fontsource-variable/geist": "5.2.9",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.69.1",
    "@sveltejs/package": "2.5.8",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.0",
    "globals": "17.7.0",
    "sugar-high": "1.2.1",
    "svelte": "5.56.4",
    "svelte-check": "4.7.1",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3"
  },
  "keywords": [
    "svelte",
    "sileo",
    "toast",
    "sonner",
    "notification"
  ],
  "sideEffects": false
}
