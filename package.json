{
  "name": "svelte-sileo",
  "version": "1.0.0",
  "description": "An opinionated, physics-based toast component for Svelte. Port of sileo.",
  "license": "MIT",
  "author": "Alexis Garcia <gvrciary@gmail.com>",
  "homepage": "https://svelte-sileo.gvrciary.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gvrciary/svelte-sileo.git"
  },
  "bugs": "https://github.com/gvrciary/svelte-sileo/issues",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package",
    "prepublishOnly": "npm run package",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@fontsource-variable/fira-code": "5.2.7",
    "@fontsource-variable/geist": "5.2.8",
    "@sveltejs/adapter-auto": "7.0.0",
    "@sveltejs/kit": "2.50.2",
    "@sveltejs/package": "2.5.7",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/vite": "4.1.18",
    "@types/node": "22",
    "globals": "17.3.0",
    "svelte": "5.49.2",
    "svelte-check": "4.3.6",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "sugar-high": "0.9.5",
    "typescript-eslint": "8.54.0",
    "vite": "7.3.1"
  },
  "keywords": [
    "svelte",
    "sileo",
    "toast",
    "sonner",
    "notification"
  ],
  "sideEffects": false
}
